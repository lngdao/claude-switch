{
  "name": "@lngdao/claude-switch",
  "version": "2026.410.4",
  "description": "TUI + CLI to manage Claude Code auth profiles (OAuth tokens, API keys, proxies) and headless setup",
  "type": "module",
  "bin": {
    "claude-switch": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lngdao/claude-switch.git"
  },
  "bugs": {
    "url": "https://github.com/lngdao/claude-switch/issues"
  },
  "homepage": "https://github.com/lngdao/claude-switch#readme",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "./scripts/release.sh",
    "release:dry": "./scripts/release.sh --dry",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "profile",
    "switch",
    "tui",
    "cli"
  ],
  "author": "longdao",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.2.0",
    "clipboardy": "^4.0.0",
    "commander": "^12.1.0",
    "ink": "^5.1.0",
    "ink-select-input": "^6.0.0",
    "ink-text-input": "^6.0.0",
    "kleur": "^4.1.5",
    "proper-lockfile": "^4.1.2",
    "react": "^18.3.1",
    "update-notifier": "^7.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^18.3.12",
    "@types/update-notifier": "^6.0.8",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.4"
  }
}
